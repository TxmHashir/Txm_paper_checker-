# 2. Add your actual API keys to .env
# 3. Never commit .env to version control
# 4. Add .env to .gitignore (already included)
#
# For CI/CD Builds (CodeMagic):
# - Set GEMINI_API_KEY as an environment secret in CodeMagic dashboard
# - The app will use this value at build/runtime
# =====================================================

# Google Gemini API Key (required)
# Get your key from: https://aistudio.google.com/apikey
# Used by: lib/services/gemini_omr_service.dart
# Model  : gemini-2.5-flash
# Purpose: OMR sheet reading — extracts student info,
#          reads bubble marks, and returns structured JSON.
GEMINI_API_KEY=your_gemini_api_key_here
